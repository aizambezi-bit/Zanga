rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global safety net - deny all writes and reads unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safe lookup helper to avoid crash when user record doesn't exist yet
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return userExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function getUserRole() {
      return userExists() ? getUserData().role : null;
    }

    function getUserBranchId() {
      return userExists() ? getUserData().branchId : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token != null && request.auth.token.email == 'aizambezi@gmail.com') ||
        (userExists() && getUserRole() == 'admin')
      );
    }

    // Matches if user has authorized roles or is the admin
    function isManager() {
      return isSignedIn() && userExists() && (getUserRole() == 'manager' || getUserRole() == 'admin');
    }

    function isAssistant() {
      return isSignedIn() && userExists() && (getUserRole() == 'assistant' || getUserRole() == 'manager' || getUserRole() == 'admin');
    }

    function isCashier() {
      return isSignedIn() && userExists() && (getUserRole() == 'cashier' || getUserRole() == 'assistant' || getUserRole() == 'manager' || getUserRole() == 'admin');
    }

    // --- USER ACCOUNT PERMISSIONS ---
    match /users/{uid} {
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid == uid);
      allow list: if isSignedIn() && (isAdmin() || (userExists() && getUserRole() == 'manager' && resource.data.branchId == getUserBranchId()));
      
      allow create: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == uid && (
          request.auth.token.email == 'aizambezi@gmail.com' || 
          (!userExists() && request.resource.data.role == 'cashier')
        ))
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == uid && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.branchId == resource.data.branchId)
      );
      
      allow delete: if isAdmin();
    }

    // --- BRANCH PERMISSIONS ---
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- PRODUCT / MEDICATION PERMISSIONS ---
    match /products/{productId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.branchId == getUserBranchId());
      allow list: if isSignedIn() && (isAdmin() || resource.data.branchId == getUserBranchId());
      allow create: if isSignedIn() && (isAdmin() || (isManager() && request.resource.data.branchId == getUserBranchId()));
      allow update: if isSignedIn() && (isAdmin() || isManager());
      allow delete: if isAdmin();
    }

    // --- SALES PERMISSIONS (POS) ---
    match /sales/{saleId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.branchId == getUserBranchId());
      allow list: if isSignedIn() && (isAdmin() || resource.data.branchId == getUserBranchId());
      allow create: if isSignedIn() && (isAdmin() || (isCashier() && request.resource.data.branchId == getUserBranchId()));
      
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- STOCK MOVEMENTS ---
    match /stockMovements/{movementId} {
      allow list, get: if isSignedIn() && (isAdmin() || resource.data.branchId == getUserBranchId());
      allow create: if isSignedIn() && (isAdmin() || isCashier());
    }

    // --- INTER-BRANCH TRANSFER PERMISSIONS ---
    match /transfers/{transferId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.sourceBranchId == getUserBranchId() || resource.data.targetBranchId == getUserBranchId());
      allow list: if isSignedIn() && (isAdmin() || resource.data.sourceBranchId == getUserBranchId() || resource.data.targetBranchId == getUserBranchId());
      allow create: if isSignedIn() && (isAdmin() || (isCashier() && request.resource.data.sourceBranchId == getUserBranchId()));
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isCashier() && (resource.data.targetBranchId == getUserBranchId() || resource.data.sourceBranchId == getUserBranchId()))
      );
      allow delete: if isAdmin();
    }

    // --- ACCOUNTING LEDGER PERMISSIONS ---
    match /accounting/{docId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.branchId == getUserBranchId());
      allow list: if isSignedIn() && (isAdmin() || (isManager() && resource.data.branchId == getUserBranchId()));
      allow create: if isSignedIn() && (isAdmin() || (isCashier() && request.resource.data.branchId == getUserBranchId()));
      allow update, delete: if isAdmin();
    }

    // --- PHARMACY SETTINGS PERMISSIONS ---
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}